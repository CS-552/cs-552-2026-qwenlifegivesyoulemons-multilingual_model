    "cfgs = get_dataset_config_names(\"wikimedia/wikipedia\")\n",
    "for lang in (\"it\", \"es\", \"zh\", \"ru\", \"hi\"):\n",
    "    print(lang, \"->\", [c for c in cfgs if c.endswith(f\".{lang}\")][:3])"
